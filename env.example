# blogger-radar / env.example
# Local development environment variables.
# Copy to .env and fill in your keys. DO NOT commit .env to git.

# === Notion (if Notion push is enabled) ===
NOTION_TOKEN=
NOTION_DATABASE_ID=

# === Email / SMTP (if Email push is enabled) ===
# Gmail example: enable 2FA → Account Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password

# === Slack (if Slack push is enabled) ===
# api.slack.com/apps → Your App → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=

# === Discord (if Discord push is enabled) ===
# Channel Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=

# === Telegram (if Telegram push is enabled) ===
# Bot token from @BotFather; chat_id from getUpdates API
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Feishu / Lark (if Feishu push is enabled) ===
# Group chat → Settings → Bots → Add Bot → Custom Bot → Copy Webhook URL
FEISHU_WEBHOOK_URL=
# FEISHU_BOT_SECRET=  # uncomment if signature verification enabled

# === WeChat Work (if WeChat push is enabled) ===
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxx

# === Twitter/X (optional — falls back to Nitter RSS if not set) ===
TWITTER_BEARER_TOKEN=

# === YouTube (optional) ===
YOUTUBE_API_KEY=

# === GitHub (optional — raises rate limit from 60 to 5000 req/hr) ===
GITHUB_TOKEN=

# === Xiaohongshu via RSSHub (optional) ===
RSSHUB_BASE_URL=
RSSHUB_ACCESS_KEY=
